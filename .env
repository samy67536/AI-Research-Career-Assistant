# ============================================================
#  AI Research & Career Assistant — Environment Variables
# ============================================================

# ── LLM API Keys ─────────────────────────────────────────────
# 💡 Gemini is FREE — get your key at https://aistudio.google.com/apikey
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_CLAUDE_KEY_HERE
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY_HERE
GEMINI_API_KEY=AIzaSy-YOUR_GEMINI_KEY_HERE
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_KEY_HERE

# ── Default LLM Provider ──────────────────────────────────────
# Recommended: gemini (free tier, no credit card)
# Options: gemini | openai | claude | deepseek
LLM_PROVIDER=gemini
LLM_MODEL=gemini-1.5-flash

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/app.db

# ── Security ──────────────────────────────────────────────────
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── File Storage ──────────────────────────────────────────────
UPLOAD_DIR=./data/uploads
VECTOR_DIR=./data/vectors
MAX_FILE_SIZE_MB=50

# ── Embedding Model ───────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── RAG Settings ──────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5

# ── App Settings ──────────────────────────────────────────────
APP_NAME=AI Research & Career Assistant
DEBUG=True
PORT=8000
